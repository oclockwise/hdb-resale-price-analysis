<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>

  <!-- Tailwind CSS loaded from CDN for styling -->
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 text-gray-800 font-sans p-8">

  <!-- Main heading -->
  <h1 class="text-3xl font-bold mb-8 text-center text-blue-800">
    <%= title %>
  </h1>

  <!-- Container with white background, padding, rounded corners and shadow -->
  <div class="max-w-lg mx-auto bg-white p-6 rounded-lg shadow-lg">
    
    <!-- Table with full width, borders, rounded corners, and shadow -->
    <table class="min-w-full border border-gray-300 rounded-md overflow-hidden shadow-sm">
      
      <!-- Table header styled with blue background and text -->
      <thead class="bg-blue-100 text-blue-900 font-semibold">
        <tr>
          <th class="p-3 border border-gray-300 text-left">Town Name</th>
          <th class="p-3 border border-gray-300 text-left">Average Resale Price ($)</th>
        </tr>
      </thead>

      <!-- Table body where rows are generated dynamically -->
      <tbody>
        <% data.forEach(row => { %>
          <tr class="hover:bg-blue-50">
            <td class="p-3 border border-gray-300"><%= row.town_name %></td>
            <td class="p-3 border border-gray-300"><%= row.avg_resale_price %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- Link back to home page -->
  <div class="max-w-lg mx-auto mt-6 text-center">
    <a href="/" class="text-blue-600 hover:underline">Back to Home</a>
  </div>

</body>
</html>
