<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 text-gray-900 font-sans p-8">

  <!-- Page title -->
  <h1 class="text-3xl font-bold mb-8 text-center text-blue-800"><%= title %></h1>

  <!-- Table container -->
  <div class="max-w-5xl mx-auto bg-white p-6 rounded-lg border border-gray-300 shadow-lg">

    <!-- Table -->
    <table class="min-w-full border border-gray-300 rounded-md overflow-hidden shadow-sm">
      <thead class="bg-blue-100 text-blue-900 font-semibold">
        <tr>
          <th class="p-3 border border-gray-300 text-left">Storey Range</th>
          <th class="p-3 border border-gray-300 text-left">Average Resale Price ($)</th>
        </tr>
      </thead>
      <tbody>
        <% data.forEach(row => { %>
          <tr class="hover:bg-blue-50">
            <td class="p-3 border border-gray-300"><%= row.storey_range %></td>
            <td class="p-3 border border-gray-300"><%= row.avg_resale_price %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>

  </div>

  <!-- Back to home link -->
  <div class="max-w-5xl mx-auto mt-6 text-center">
    <a href="/" class="text-blue-600 hover:underline">Back to Home</a>
  </div>

</body>
</html>
