<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    .tab-content { display: none; }
    .tab-content.active { display: table-row-group; }
  </style>
</head>
<body class="bg-gray-50 text-gray-900 font-sans p-8">

  <h1 class="text-3xl font-bold mb-8 text-center text-blue-800"><%= title %></h1>

  <% 
    // Get unique towns sorted alphabetically
    let towns = [...new Set(data.map(r => r.town_name))].sort();
  %>

  <!-- Town tabs -->
  <div class="max-w-5xl mx-auto mb-6 flex space-x-4 justify-center flex-wrap">
    <% towns.forEach((town, i) => { %>
      <button
        class="tab-btn px-4 py-2 rounded-t-lg border border-b-0 border-gray-300 <%= i === 0 ? 'bg-white font-semibold' : 'bg-gray-200' %>"
        data-town="<%= town %>"><%= town %></button>
    <% }) %>
  </div>

  <div class="max-w-5xl mx-auto bg-white p-6 rounded-b-lg border border-gray-300 shadow-lg">

    <table class="min-w-full border border-gray-300 rounded-md overflow-hidden shadow-sm">
      <thead class="bg-blue-100 text-blue-900 font-semibold">
        <tr>
          <th class="p-3 border border-gray-300 text-left">Flat Type</th>
          <th class="p-3 border border-gray-300 text-left">Transaction Count</th>
        </tr>
      </thead>

      <% towns.forEach((town, i) => { %>
        <tbody class="tab-content <%= i === 0 ? 'active' : '' %>" data-town="<%= town %>">
          <% data.filter(r => r.town_name === town).forEach(row => { %>
            <tr class="hover:bg-blue-50">
              <td class="p-3 border border-gray-300"><%= row.flat_type %></td>
              <td class="p-3 border border-gray-300"><%= row.transaction_count %></td>
            </tr>
          <% }) %>
        </tbody>
      <% }) %>
    </table>

  </div>

  <div class="max-w-5xl mx-auto mt-6 text-center">
    <a href="/" class="text-blue-600 hover:underline">Back to Home</a>
  </div>

  <script>
    const tabs = document.querySelectorAll('.tab-btn');
    const tabContents = document.querySelectorAll('.tab-content');

    function activateTab(town) {
      tabContents.forEach(tc => {
        tc.classList.toggle('active', tc.dataset.town === town);
      });

      tabs.forEach(btn => {
        btn.classList.toggle('bg-white', btn.dataset.town === town);
        btn.classList.toggle('font-semibold', btn.dataset.town === town);
        btn.classList.toggle('bg-gray-200', btn.dataset.town !== town);
      });
    }

    tabs.forEach(btn => {
      btn.addEventListener('click', () => activateTab(btn.dataset.town));
    });
  </script>

</body>
</html>
